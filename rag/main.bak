"""
Main Runner: Evaluates concurrent ingestion and hybrid sub-supplier inference framework.
"""
import os
import json
from settings import safe_print
from engine import run_concurrent_ingestion_pipeline, process_esg_compliance_query

if __name__ == "__main__":
    # 로컬 테스트 디렉토리 생성
    os.makedirs("./esg_pdf_files", exist_ok=True)
    os.makedirs("./esg_excel_files", exist_ok=True)
    
    print("=" * 60)
    print("💡 [Step 1] PDF(pgvector) & Excel(MariaDB) 동시 적재 파이프라인 트리거")
    print("=" * 60)
    
    # PDF 파일과 Excel 파일 동시 다발 처리 프로세스 시작
    run_concurrent_ingestion_pipeline(pdf_dir="./esg_pdf_files", excel_dir="./esg_excel_files")
    
    print("\n" + "=" * 60)
    print("💡 [Step 2] 하이브리드 서치 기반 공급망 리스크 전파 추론 테스트")
    print("=" * 60)
    
    # 공급망 오염 검증 시나리오 구동 (3차 협력사 Comilog 아동노동 검출 시나리오)
    sample_query = "저희 보크사이트 채굴 현장에서 아동노동 1건이 현장 감사에서 확인되었습니다."
    sample_partner = "Comilog"
    
    try:
        response_payload = process_esg_compliance_query(
            user_query=sample_query,
            partner_name=sample_partner
        )
        
        print("\n[API Endpoint 전달용 최종 Payload Output]")
        print("-" * 60)
        print(json.dumps(response_payload, indent=4, ensure_ascii=False))
        print("-" * 60)
        
    except Exception as e:
        safe_print(f"[테스트 실패] 메인 스트림 엔진 구동 중 예외 발생: {e}")